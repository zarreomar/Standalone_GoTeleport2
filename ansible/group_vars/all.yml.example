---
# Global Variables for GoTeleport Deployment
# Copy this file to ansible/group_vars/all.yml and fill in with your values

# Docker Image Configuration
image_name: "public.ecr.aws/gravitational/teleport-distroless:18.7.2"

# Domain and SSL
public_domain: "goteleport.yourdomain.com"
acme_email: "admin@yourdomain.com"

# Host Network Interfaces
host_network_public: "ens3"
host_network_internal: "ens4"
public_ip: "203.0.113.10"        # Replace with actual ens3 IP
internal_ip: "10.100.50.10"      # Replace with actual ens4 IP

# Network Subnets
swarm_subnet: "10.0.9.0/24"
internal_subnet: "172.16.0.0/12"

# Teleport Service Configuration
service_name: "gotTeleport"
cluster_name: "goteleport-prod"
deploy_environment: "production"
log_severity: "INFO"
session_recording: "all"

# Service Deployment
replicas: 3
update_parallelism: 1
update_delay: "30s"
health_check_interval: "30s"
health_check_timeout: "10s"
health_check_path: "/health"

# Storage Configuration
storage_path: "/var/lib/teleport"
storage_type: "postgresql"

# PostgreSQL backend for Teleport
postgres_image_name: "local/goteleport-postgres:15"
postgres_host: "postgres"
postgres_port: 5432
postgres_user: "teleport"
postgres_password: "change-me-with-a-secret"
postgres_backend_db: "teleport_backend"
postgres_audit_db: "teleport_audit"
postgres_sslmode: "disable"

# MinIO-backed session storage for Teleport recordings
minio_image_name: "minio/minio:latest"
minio_mc_image_name: "minio/mc:latest"
minio_root_user: "minioadmin"
minio_root_password: "change-me-with-a-secret"
minio_bucket: "teleport-sessions"
minio_region: "us-east-1"
minio_endpoint: "minio:9000"
minio_console_port: 9001
teleport_audit_sessions_uri: "s3://teleport-sessions/records?region=us-east-1&endpoint=minio:9000&insecure=true"

# Optional: Docker Registry Credentials (if using private registry)
# registry_username: "your_username"
# registry_password: "your_password"
# registry_email: "your_email@example.com"

# Optional: Slack/Monitoring Notifications
# notification_webhook: "https://hooks.slack.com/services/YOUR/WEBHOOK/URL"
# alert_threshold_cpu: 80
# alert_threshold_memory: 85
# alert_threshold_disk: 90
