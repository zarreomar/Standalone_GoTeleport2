# GoTeleport Configuration Template
# Variables from group_vars or extra-vars will populate {{ }} placeholders

teleport:
  nodename: gotTeleport-{{ inventory_hostname }}
  server_role: local
  data_dir: /var/lib/teleport

auth_service:
  enabled: "yes"
  cluster_name: "{{ cluster_name | default('gotTeleport-cluster') }}"
  authentication:
    type: local
  session_recording: "{{ session_recording | default('all') }}"

ssh_service:
  enabled: "yes"
  bind_address: "0.0.0.0:22"
  auto_provision: "yes"
  labels:
    env: "{{ environment | default('production') }}"
    cluster: "{{ cluster_name | default('gotTeleport-cluster') }}"

proxy_service:
  enabled: "yes"
  bind_address: "0.0.0.0:3023"
  public_addr: "{{ public_domain }}:443"
  acme:
    enabled: false
    # SSL cert management delegated to Traefik reverse proxy

kubernetes_service:
  enabled: "no"

database_service:
  enabled: "no"

storage:
  type: dir
  path: /var/lib/teleport/backend

logging:
  version: v2
  severity: "{{ log_severity | default('INFO') }}"

cache:
  enabled: "yes"
  ttl: 5m
