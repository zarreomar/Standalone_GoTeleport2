# Teleport configuration rendered for containerized deployment.
#
# The runtime config is mounted into the container at /etc/teleport/teleport.yaml.

version: v3

teleport:
  data_dir: {{ storage_path | default('/var/lib/teleport') }}
  storage:
    type: postgresql
    conn_string: "postgresql://{{ postgres_user }}:{{ postgres_password }}@{{ postgres_host }}:{{ postgres_port }}/{{ postgres_backend_db }}?sslmode={{ postgres_sslmode }}&pool_max_conns=20"
    audit_events_uri:
      - "postgresql://{{ postgres_user }}:{{ postgres_password }}@{{ postgres_host }}:{{ postgres_port }}/{{ postgres_audit_db }}?sslmode={{ postgres_sslmode }}"
    audit_sessions_uri: "{{ teleport_audit_sessions_uri | default('file:///var/lib/teleport/log') }}"
  log:
    output: stderr
    severity: "{{ log_severity | default('INFO') }}"

auth_service:
  enabled: true
  cluster_name: "{{ cluster_name | default('gotTeleport-cluster') }}"
  authentication:
    type: local
  session_recording_config:
    mode: "{{ session_recording | default('node') }}"

ssh_service:
  enabled: true
  listen_addr: 0.0.0.0:3022
  public_addr: "{{ public_domain }}:3022"
  labels:
    env: "{{ deploy_environment | default('production') }}"
    cluster: "{{ cluster_name | default('gotTeleport-cluster') }}"

proxy_service:
  enabled: true
  web_listen_addr: 0.0.0.0:3080
  public_addr: "{{ public_domain }}:443"
  ssh_public_addr: "{{ public_domain }}:3023"
  tunnel_public_addr: "{{ public_domain }}:3024"
